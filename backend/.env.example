# ============================================================
# Chibitek Plugin Platform — Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/chibitek_plugins?schema=public"

# Redis (for BullMQ job queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Anthropic / Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Cloudflare R2 Storage (S3-compatible)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=chibitek-plugins
R2_PUBLIC_URL=https://your-r2-public-url.r2.dev

# GitHub (for triggering compilation workflows)
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=erickgrau
GITHUB_REPO=chris-grau-plugin-platform
GITHUB_WORKFLOW_ID=compile-plugin.yml

# Auth (shared secret for service-to-service auth)
API_SECRET=your-strong-api-secret-here

# CORS
CORS_ORIGIN=http://localhost:3000
